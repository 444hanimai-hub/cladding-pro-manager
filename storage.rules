rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Документы проекта — для авторизованных пользователей, лимит 50 МБ.
    // Фильтр по contentType временно отключён до подтверждения, что загрузка работает.
    match /projects/{projectId}/documents/{file=**} {
      allow read:   if request.auth != null;
      allow delete: if request.auth != null;
      allow write:  if request.auth != null
                     && request.resource.size < 50 * 1024 * 1024;
    }

    // Заглушка для остальных путей — запрет всего, чтобы случайно не открыть бакет.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
