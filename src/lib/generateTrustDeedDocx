// ── Константы ─────────────────────────────────────────────────────────────────

const FONT = 'Times New Roman';
const PAGE_W = 11906;
const ML = 1440; const MR = 720; const MT = 720; const MB = 720;
const CW = PAGE_W - ML - MR; // 9746
const STUB_W = 4200;
const SEP_W = 160;
const MAIN_W = CW - STUB_W - SEP_W; // 5386

const noBorder = { style: BorderStyle.NONE, size: 0, color: 'FFFFFF' };
const thinBorder = { style: BorderStyle.SINGLE, size: 4, color: '000000' };
const noBorders = { top: noBorder, bottom: noBorder, left: noBorder, right: noBorder };
const allBorders = { top: thinBorder, bottom: thinBorder, left: thinBorder, right: thinBorder };

// ── Вспомогательные функции ───────────────────────────────────────────────────

function r(text: string, opts: { size?: number; bold?: boolean; italic?: boolean } = {}): TextRun {
  return new TextRun({ text: String(text ?? ''), font: FONT, size: opts.size ?? 18, bold: !!opts.bold, italics: !!opts.italic });
}

function p(
  children: TextRun | TextRun[],
  opts: { align?: (typeof AlignmentType)[keyof typeof AlignmentType]; before?: number; after?: number } = {}
): Paragraph {
  return new Paragraph({
    alignment: opts.align ?? AlignmentType.LEFT,
    spacing: { before: opts.before ?? 0, after: opts.after ?? 0, line: 240 },
    children: Array.isArray(children) ? children : [children],
  });
}

function tc(
  children: Paragraph | Paragraph[],
  opts: {
    width?: number;
    span?: number;
    borders?: typeof noBorders;
    align?: (typeof VerticalAlign)[keyof typeof VerticalAlign];
  } = {}
): TableCell {
  return new TableCell({
    borders: opts.borders ?? noBorders,
    width: opts.width ? { size: opts.width, type: WidthType.DXA } : undefined,
    verticalAlign: opts.align ?? VerticalAlign.CENTER,
    columnSpan: opts.span,
    shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' },
    margins: { top: 40, bottom: 40, left: 80, right: 80 },
    children: Array.isArray(children) ? children : [children],
  });
}

function underLine(value: string, label: string, width: number, textSize = 16): TableCell {
  return new TableCell({
    borders: noBorders,
    width: { size: width, type: WidthType.DXA },
    verticalAlign: VerticalAlign.BOTTOM,
    shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' },
    margins: { top: 20, bottom: 20, left: 60, right: 60 },
    children: [
      p(r(value, { size: textSize }), { align: AlignmentType.CENTER }),
      new Paragraph({
        border: { bottom: { style: BorderStyle.SINGLE, size: 4, color: '000000', space: 0 } },
        spacing: { before: 0, after: 0 }, children: [],
      }),
      p(r(label, { size: 12 }), { align: AlignmentType.CENTER }),
    ],
  });
}

function lineRow(labelW: number, label: string, valueW: number, value: string, noteLabel?: string): TableRow[] {
  const rows: TableRow[] = [
    new TableRow({
      children: [
        tc(p(r(label, { size: 16 })), { width: labelW }),
        new TableCell({
          borders: { ...noBorders, bottom: thinBorder },
          width: { size: valueW, type: WidthType.DXA },
          shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' },
          margins: { top: 20, bottom: 0, left: 80, right: 80 },
          children: [p(r(value, { size: 16 }))],
        }),
      ],
    }),
  ];
  if (noteLabel) {
    rows.push(new TableRow({
      children: [
        tc(p(r('')), { width: labelW }),
        tc(p(r(noteLabel, { size: 12 }), { align: AlignmentType.CENTER }), { width: valueW }),
      ],
    }));
  }
  return rows;
}

