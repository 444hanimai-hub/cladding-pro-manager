        new TableCell({ borders: allBorders, width: { size: col3, type: WidthType.DXA }, shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' }, margins: { top: 60, bottom: 60, left: 80, right: 80 }, children: [p(r(data.materialUnit, { size: 16 }), { align: AlignmentType.CENTER })] }),
        new TableCell({ borders: allBorders, width: { size: col4, type: WidthType.DXA }, shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' }, margins: { top: 60, bottom: 60, left: 80, right: 80 }, children: [p(r(`${data.quantityText} (${data.quantity})`, { size: 16 }), { align: AlignmentType.CENTER })] }),
      ] }),
    ],
  }));

  // Подписи
  items.push(p(r('')));

  // Подпись получателя
  items.push(new Table({
    width: { size: MAIN_W, type: WidthType.DXA },
    columnWidths: [3200, MAIN_W - 3200],
    borders: { top: noBorder, bottom: noBorder, left: noBorder, right: noBorder, insideH: noBorder, insideV: noBorder },
    rows: [
      new TableRow({ children: [
        tc(p(r('Подпись лица, получившего доверенность', { size: 16 })), { width: 3200 }),
        new TableCell({ borders: { ...noBorders, bottom: thinBorder }, width: { size: MAIN_W - 3200, type: WidthType.DXA }, shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' }, margins: { top: 20, bottom: 0, left: 80, right: 80 }, children: [p(r(''))] }),
      ] }),
    ],
  }));

  // Руководитель + главбух
  for (const [title, name] of [['Руководитель', data.headName], ['Главный бухгалтер', data.chiefAccountantName]]) {
    items.push(new Table({
      width: { size: MAIN_W, type: WidthType.DXA },
      columnWidths: [1800, 1200, 700, MAIN_W - 1800 - 1200 - 700],
      borders: { top: noBorder, bottom: noBorder, left: noBorder, right: noBorder, insideH: noBorder, insideV: noBorder },
      rows: [
        new TableRow({ children: [
          tc(p(r(title, { size: 16, bold: true })), { width: 1800 }),
          new TableCell({ borders: { ...noBorders, bottom: thinBorder }, width: { size: 1200, type: WidthType.DXA }, shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' }, margins: { top: 20, bottom: 0, left: 80, right: 80 }, children: [p(r(''))] }),
          tc(p(r('  М.П.', { size: 16 })), { width: 700 }),
          new TableCell({ borders: { ...noBorders, bottom: thinBorder }, width: { size: MAIN_W - 1800 - 1200 - 700, type: WidthType.DXA }, shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' }, margins: { top: 20, bottom: 0, left: 80, right: 80 }, children: [p(r(name, { size: 16 }), { align: AlignmentType.CENTER })] }),
        ] }),
        new TableRow({ children: [
          tc(p(r('')), { width: 1800 }),
          tc(p(r('подпись', { size: 12 }), { align: AlignmentType.CENTER }), { width: 1200 }),
          tc(p(r('')), { width: 700 }),
          tc(p(r('расшифровка подписи', { size: 12 }), { align: AlignmentType.CENTER }), { width: MAIN_W - 1800 - 1200 - 700 }),
        ] }),
      ],
    }));
  }

  return items;
}

// ── Главная функция ───────────────────────────────────────────────────────────

export async function generateTrustDeedDocx(data: TrustDeedDocxData): Promise<Blob> {
  // Компонуем корешок и основную часть в один ряд таблицы
  const doc = new Document({
    sections: [{
      properties: {
        page: {
          size: { width: PAGE_W, height: 16838 },
          margin: { top: MT, right: MR, bottom: MB, left: ML },
        },
      },
      children: [
        new Table({
          width: { size: CW, type: WidthType.DXA },
          columnWidths: [STUB_W, SEP_W, MAIN_W],
          borders: { top: noBorder, bottom: noBorder, left: noBorder, right: noBorder, insideH: noBorder, insideV: noBorder },
          rows: [
            new TableRow({
              children: [
                // Корешок
                new TableCell({
                  borders: noBorders,
                  width: { size: STUB_W, type: WidthType.DXA },
                  shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' },
                  margins: { top: 40, bottom: 40, left: 0, right: 80 },
                  children: [buildStub(data)],
                }),
                // Вертикальный разделитель (пунктир)
                new TableCell({
                  borders: {
                    top: noBorder, bottom: noBorder,
                    left: { style: BorderStyle.DASHED, size: 4, color: '000000' },
                    right: { style: BorderStyle.DASHED, size: 4, color: '000000' },
                  },
                  width: { size: SEP_W, type: WidthType.DXA },
                  shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' },
                  children: [p(r('✂', { size: 14 }), { align: AlignmentType.CENTER })],
                }),
                // Основная часть
                new TableCell({
                  borders: noBorders,
                  width: { size: MAIN_W, type: WidthType.DXA },
                  shading: { type: ShadingType.CLEAR, fill: 'FFFFFF' },
                  margins: { top: 40, bottom: 40, left: 80, right: 0 },
                  children: buildMain(data),
                }),
              ],
            }),
          ],
        }),
      ],
    }],
  });

  const buffer = await Packer.toBuffer(doc);
  return new Blob([buffer], { type: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document' });
}

// ── Вспомогательная функция скачивания ───────────────────────────────────────

export function downloadBlob(blob: Blob, filename: string): void {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}
